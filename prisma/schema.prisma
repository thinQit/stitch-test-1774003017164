generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  createdAt    DateTime @default(now())
}

model Feature {
  id             String @id @default(cuid())
  title          String
  description    String
  icon           String
  highlightColor String
}

model PricingTier {
  id           String  @id @default(cuid())
  name         String
  monthlyPrice Float
  isCustom     Boolean @default(false)
  features     String
}

model Subscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  planInterest String?
  createdAt    DateTime @default(now())
}

model EnterpriseContact {
  id          String   @id @default(cuid())
  companyName String
  contactName String
  email       String
  message     String
  createdAt   DateTime @default(now())
}
