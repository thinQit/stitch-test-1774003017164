generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model PricingTier {
  id            String  @id @default(cuid())
  name          String?
  pricePerMonth Float?
  currency      String?
  features      String?
  stripePriceId String?
  isCustom      Boolean @default(false)
}

model Feature {
  id      String  @id @default(cuid())
  title   String?
  summary String?
  icon    String?
}

model Lead {
  id           String   @id @default(cuid())
  email        String?
  name         String?
  company      String?
  planInterest String?
  createdAt    DateTime @default(now())
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  role         String?
  passwordHash String
  createdAt    DateTime @default(now())
}
